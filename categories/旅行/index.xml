width="1706"
height="1279"
srcset="https://kaigezheng.github.io/p/travel3/img/8_hu16575218777963081281.jpg 480w, https://kaigezheng.github.io/p/travel3/img/8_hu12630115984413032679.jpg 1024w"
loading="lazy"
alt="明太子西葫芦（这家做的一般）"
