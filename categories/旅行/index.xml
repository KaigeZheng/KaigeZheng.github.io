class="gallery-image"
data-flex-grow="116"
data-flex-basis="278px"
> &lt;img src="https://kaigezheng.github.io/p/travel3/img/2.jpg"
width="1279"
height="1706"
srcset="https://kaigezheng.github.io/p/travel3/img/2_hu7973616275703796971.jpg 480w, https://kaigezheng.github.io/p/travel3/img/2_hu9969905703245958914.jpg 1024w"
